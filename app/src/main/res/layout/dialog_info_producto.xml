<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Información del Producto"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/ivProductoInfo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:background="#F3F4F6"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvNombreInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Producto"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvCategoriaInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precio Venta"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
                <TextView
                    android:id="@+id/tvPrecioInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Costo"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
                <TextView
                    android:id="@+id/tvCostoInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0"
                    android:textSize="16sp"
                    android:textColor="#374151" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock Total"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
                <TextView
                    android:id="@+id/tvStockInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#166534" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tallas disponibles:"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvTallasInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="35, 36, 37..."
            android:textSize="14sp"
            android:textColor="#374151"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnCerrarInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar"
            android:layout_marginTop="24dp"
            android:backgroundTint="#1F2937"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

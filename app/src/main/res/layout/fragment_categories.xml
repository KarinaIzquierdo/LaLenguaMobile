<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- Botón Volver -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnVolverInicio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Volver al inicio"
            android:scaleType="fitCenter"
            android:padding="8dp"
            app:tint="#000000" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <!-- MUJER -->
            <LinearLayout
                android:id="@+id/btnMujer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivMujer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />
                    </androidx.cardview.widget.CardView>
                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="Mujer"
                    android:textColor="#333333"
                    android:textSize="26sp" />
            </LinearLayout>

            <!-- HOMBRE -->
            <LinearLayout
                android:id="@+id/btnHombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivHombre"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />
                    </androidx.cardview.widget.CardView>
                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="Hombre"
                    android:textColor="#333333"
                    android:textSize="26sp" />
            </LinearLayout>

            <!-- NIÑOS -->
            <LinearLayout
                android:id="@+id/btnNinos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivNinos"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />
                    </androidx.cardview.widget.CardView>
                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="niños"
                    android:textColor="#333333"
                    android:textSize="26sp" />
            </LinearLayout>

            <!-- PISAHUEVOS -->
            <LinearLayout
                android:id="@+id/btnPisahuevos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivPisahuevos"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />
                    </androidx.cardview.widget.CardView>
                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="Pisa huevos"
                    android:textColor="#333333"
                    android:textSize="26sp" />
            </LinearLayout>

            <!-- PERSONALIZADOS -->
            <LinearLayout
                android:id="@+id/btnPersonalizados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivPersonalizados"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />
                    </androidx.cardview.widget.CardView>
                    <View
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:text="Personalizados"
                    android:textColor="#333333"
                    android:textSize="24sp" />
            </LinearLayout>

            <!-- OUTLET -->
            <LinearLayout
                android:id="@+id/btnOutlet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:layout_marginTop="16dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/ivOutlet"
                    android:layout_width="280dp"
                    android:layout_height="120dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="fitCenter" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
